import { createFileRoute } from "@tanstack/react-router";
import { useI18n } from "@/i18n/I18nProvider";
import { Reveal, RevealItem } from "@/components/site/Reveal";
import portrait from "@/assets/story-portrait.jpg";
import detail from "@/assets/story-detail.jpg";

export const Route = createFileRoute("/story")({
  head: () => ({
    meta: [
      { title: "Notre histoire — Ô Saveurs fruitées" },
      { name: "description", content: "L'histoire d'Ô Saveurs fruitées : un food truck artisanal entre Mortagne-sur-Gironde et Miami." },
      { property: "og:title", content: "Notre histoire — Ô Saveurs fruitées" },
      { property: "og:description", content: "Du verger à la rue, sans détour." },
      { property: "og:image", content: portrait },
    ],
  }),
  component: StoryPage,
});

function StoryPage() {
  const { t } = useI18n();
  return (
    <div className="pt-32 md:pt-40">
      <div className="mx-auto max-w-4xl px-5 md:px-8">
        <Reveal className="text-center mb-14">
          <RevealItem>
            <p className="text-xs uppercase tracking-[0.3em] text-accent font-semibold mb-4">
              {t.story.eyebrow}
            </p>
          </RevealItem>
          <RevealItem>
            <h1 className="font-display text-5xl md:text-7xl font-black text-balance">
              {t.pages.storyTitle}
            </h1>
          </RevealItem>
        </Reveal>

        <Reveal className="space-y-10">
          <RevealItem>
            <div className="aspect-[16/10] overflow-hidden rounded-2xl">
              <img src={portrait} alt="Portrait du fondateur" className="size-full object-cover" loading="lazy" />
            </div>
          </RevealItem>
          <RevealItem>
            <p className="text-lg md:text-xl leading-relaxed text-foreground/85 text-pretty">
              {t.story.body}
            </p>
          </RevealItem>
          <RevealItem>
            <blockquote className="border-l-4 border-accent pl-6 py-3 font-display text-2xl md:text-3xl italic text-accent">
              {t.story.pull}
            </blockquote>
          </RevealItem>
          <RevealItem>
            <div className="aspect-[16/10] overflow-hidden rounded-2xl">
              <img src={detail} alt="Détail de la préparation" className="size-full object-cover" loading="lazy" />
            </div>
          </RevealItem>
          <RevealItem>
            <p className="text-base md:text-lg leading-relaxed text-foreground/75 text-pretty">
              {t.featured.body}
            </p>
          </RevealItem>
        </Reveal>
      </div>
    </div>
  );
}
